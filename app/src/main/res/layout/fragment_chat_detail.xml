<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/main_dark">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="0dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="@color/main_dark_blue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <ImageView
                android:id="@+id/ivInfoAlert"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:layout_marginTop="5dp"
                android:src="@drawable/ic_info"
                android:contentDescription="@string/model_icon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/alert_will_be_archived"
                android:textColor="@color/main_white"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:paddingHorizontal="8dp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="63dp"
        android:padding="8dp"
        android:background="@color/main_dark_blue">

        <ImageView
            android:id="@+id/ivModelIcon"
            android:layout_width="23dp"
            android:layout_height="23dp"
            android:src="@drawable/ic_default_chat"
            android:contentDescription="@string/model_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/wrapWaverForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="2dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/main_white"
            app:layout_constraintStart_toEndOf="@id/ivModelIcon"
            app:layout_constraintEnd_toStartOf="@id/ivSendButton"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <EditText
                android:id="@+id/etMessageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minLines="1"
                android:maxLines="5"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:padding="12dp"
                android:textColor="@color/main_dark"
                android:textColorHint="@color/hint_input"
                android:hint="@string/hint_enter_message"
                android:textSize="16sp"
                android:background="@null"
                android:scrollbars="vertical"
                android:focusable="true"
                android:focusableInTouchMode="true" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/ivSendButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_send_button"
            android:contentDescription="@string/send"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>