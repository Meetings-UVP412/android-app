<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_dark"
    android:layout_marginTop="75dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cvAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#2D2D3D"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Внимание! Текст транскрипции хранится на сервере 3 часа после завершения встречи, после создать новый чат или перегенерировать итоги будет невозможно"
            android:textColor="@color/main_white"
            android:background="@color/main_dark_blue"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"/>
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/cvAlert"
        app:layout_constraintBottom_toTopOf="@id/llInput"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/llInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_gravity="bottom"
        android:background="@color/main_dark_blue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivModelIcon"
            android:layout_width="23dp"
            android:layout_height="23dp"
            android:src="@drawable/ic_default_chat"
            android:contentDescription="Иконка модели"
            android:layout_gravity="center_vertical"/>

        <EditText
            android:id="@+id/etMessageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@color/main_white"
            android:padding="12dp"
            android:layout_marginHorizontal="10dp"
            android:textColor="@android:color/white"
            android:hint="Введите сообщение..."
            android:textColorHint="@color/hint_input"
            android:textSize="16sp"
            android:maxLines="5"
            android:inputType="textMultiLine"/>

        <ImageView
            android:id="@+id/ivSendButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_send_button"
            android:contentDescription="@string/send"
            android:layout_gravity="center_vertical"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>