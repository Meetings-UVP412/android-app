<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/main_dark">

    <ImageView
        android:id="@+id/ivModelIcon"
        android:layout_width="21dp"
        android:layout_height="21dp"
        android:contentDescription="@string/model_icon"
        android:src="@drawable/ic_default_chat"
        android:layout_marginTop="15dp"
        app:layout_constraintEnd_toStartOf="@+id/tvMessage"
        app:layout_constraintTop_toTopOf="@+id/tvMessage"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:backgroundTint="#2D2D3D"
        android:lineSpacingExtra="4dp"
        android:padding="12dp"
        android:radius="16dp"
        android:text="shhshdhdkmefkmefmkedfkmekfnkrmfkemfmkemkefnkemfkemfkemfshhshdhdkmefkmefmkedfkmekfnkrmfkemfmkemkefnkemfkemfkemfshhshdhdkmefkmefmkedfkmekfnkrmfkemfmkemkefnkemfkemfkemf"
        android:textColor="@color/main_white"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@+id/ivModelIcon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>