<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_dark"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilMeetingName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="23dp"
        app:boxStrokeWidth="0dp"
        android:background="@color/main_dark_blue"
        app:layout_constraintTop_toTopOf="parent" >

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMeetingName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/meeting_name"
            android:textColor="@color/main_white"
            android:textColorHint="@color/meeting_hint" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateMeeting"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/create_meeting"
        android:textColor="@color/main_dark"
        android:layout_marginTop="32dp"
        android:textSize="16sp"
        android:fontFamily="@font/roboto_medium"
        android:backgroundTint="@color/main_white"
        app:layout_constraintTop_toBottomOf="@id/tilMeetingName"
        app:cornerRadius="12dp" />

</androidx.constraintlayout.widget.ConstraintLayout>