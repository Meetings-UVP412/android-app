<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/main_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cvMeetingName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            app:cardBackgroundColor="@color/main_dark_blue"
            app:cardCornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_medium"
                    android:text="@string/meeting_name_edit"
                    android:textColor="@color/meeting_hint"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etMeetingName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:fontFamily="@font/roboto_medium"
                    android:inputType="textPersonName"
                    android:textColor="@color/main_white"
                    android:textSize="17sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:clickable="false"
            android:focusable="false"
            app:cardBackgroundColor="@color/main_dark_blue"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cvMeetingName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/time_date_meeting"
                    android:fontFamily="@font/roboto_medium"
                    android:textSize="14sp"
                    android:textColor="@color/meeting_hint"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDateTime"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/main_white"
                        android:fontFamily="@font/roboto_medium"
                        android:textSize="17sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvLink"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:clickable="false"
            android:focusable="false"
            app:cardBackgroundColor="@color/main_dark_blue"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cvDateTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/link"
                    android:fontFamily="@font/roboto_medium"
                    android:textSize="14sp"
                    android:textColor="@color/meeting_hint"/>

                <EditText
                    android:id="@+id/etLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:textColor="@color/main_white"
                    android:textSize="17sp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:fontFamily="@font/roboto_medium"
                    android:inputType="textUri"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvComment"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/main_dark_blue"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cvLink"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/comment"
                    android:fontFamily="@font/roboto_medium"
                    android:textSize="14sp"
                    android:textColor="@color/meeting_hint"/>

                <EditText
                    android:id="@+id/etComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:textColor="@color/main_white"
                    android:textSize="17sp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:fontFamily="@font/roboto_medium"
                    android:inputType="textMultiLine"
                    android:minLines="3"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cvAudio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/main_dark_blue"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cvComment"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Аудио-файл *"
                    android:fontFamily="@font/roboto_medium"
                    android:textSize="14sp"
                    android:textColor="@color/meeting_hint"/>

                <LinearLayout
                    android:id="@+id/llAudioContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/btnDeleteAudio"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@null"
                        android:src="@drawable/ic_delete"
                        android:contentDescription="@string/delete_audio"
                        android:visibility="gone"/>

                    <ImageView
                        android:id="@+id/ivWaveform"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:backgroundTint="@color/main_dark"
                        android:src="@drawable/cisco"
                        android:contentDescription="@string/waveform"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUploadAudio"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        app:icon="@drawable/ic_upload_file"
                        android:background="@null"
                        android:layout_marginTop="8dp"
                        android:text="@string/upload_audio"
                        android:textColor="@color/main_dark_blue"
                        android:textSize="16sp"
                        android:fontFamily="@font/roboto_medium"
                        android:backgroundTint="@color/main_white"
                        android:drawableStart="@drawable/ic_upload_file"
                        android:drawablePadding="8dp"
                        android:gravity="start|center_vertical"
                        app:iconPadding="8dp"
                        app:iconGravity="textStart"
                        app:iconTint="@color/main_dark_blue"
                        app:cornerRadius="12dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateMeeting"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:text="@string/btn_create_meeting"
            android:textSize="16sp"
            android:textColor="@color/main_dark"
            android:fontFamily="@font/roboto_medium"
            android:enabled="false"
            android:backgroundTint="@color/main_white"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/cvAudio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:cornerRadius="12dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>